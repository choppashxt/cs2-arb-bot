# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local runs, load it with:
#   set -a && source .env && set +a && python scanner.py
#
# For GitHub Actions, add these same names under
# Settings > Secrets and variables > Actions (do NOT commit your real .env).

# --- CSFloat (buy-side listings; also an instant sell venue via buy orders) ---
# Required for CSFloat. Free key from your CSFloat account (developer tab).
CSFLOAT_API_KEY=

# CSFloat's buy-order endpoint is NOT in their official docs (community-known).
# Set to false to use CSFloat for listings only, not as an instant sell venue.
CSFLOAT_BUY_ORDERS_ENABLED=true

# --- DMarket (buy-side listings + buy-order "targets" sell venue) ---
# Both keys required for DMarket. Generate them in DMarket account > Trading API.
# Leave blank to skip DMarket entirely.
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=

# --- CSGORoll (OPTIONAL, off by default — read the caveats) ---
# CSGORoll has NO official public API. Enabling this scrapes the unofficial
# GraphQL endpoint its own web client uses (owner-authorized). It may violate
# their ToS and can stop working or get blocked at any time; the scanner skips
# on any block (no evasion). Prices are COINS -> converted via the rate below
# and never treated as a cash exit.
CSGOROLL_ENABLED=false
# Realistic cash value of one CSGORoll coin for YOU (coins aren't withdrawable;
# you exit by withdrawing a skin and reselling it).
CSGOROLL_COIN_USD=0.66

# --- Discord ---
# Optional. Server Settings > Integrations > Webhooks > New Webhook.
# Leave blank to just print results to the console.
DISCORD_WEBHOOK_URL=

# --- Reporting window ---
# Minimum net spread (%) after fees to report.
MIN_SPREAD_PCT=15
# Spreads above this are treated as data artifacts and logged, never alerted.
MAX_PLAUSIBLE_SPREAD_PCT=40
# Ignore items cheaper than this (USD).
MIN_ITEM_PRICE_USD=5

# --- False-spread guards ---
# Discard any single listing/bid deviating more than this (%) from the item's
# robust reference price before any spread math.
MAX_DEVIATION_PCT=25
# Liquidity floors: recent sales (last 7d, where data exists) and quantity
# behind the top buy order (a lone qty-1 bid is bait).
MIN_RECENT_SALES=3
MIN_BUY_ORDER_DEPTH=2

# --- Trade-lock safety ---
# Only flag cross-platform opps where the bought item is tradable NOW.
REQUIRE_TRADABLE_NOW=true
# Keep opps whose lock status is unknown (labeled) instead of dropping them.
TREAT_UNKNOWN_TRADABLE_AS_OK=false
# Include list-and-wait exits (clearly marked "NOT INSTANT").
ALLOW_NOT_INSTANT=true

# --- Fees (%) — confirm against your account tier ---
# Filling a buy order (instant exit):
CSFLOAT_BUY_ORDER_FEE_PCT=2
DMARKET_BUY_ORDER_FEE_PCT=5
# Normal listing sale (not-instant exit):
SKINPORT_SELL_FEE_PCT=8
CSFLOAT_SELL_FEE_PCT=2
DMARKET_SELL_FEE_PCT=5
