# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For local runs, load it with:
#   set -a && source .env && set +a && python scanner.py
#
# For GitHub Actions, add these same names under
# Settings > Secrets and variables > Actions (do NOT commit your real .env).

# --- CSFloat (buy-side listings; also a buy-order sell venue) ---
# Required for CSFloat. Free key from your CSFloat account (developer tab).
CSFLOAT_API_KEY=

# CSFloat's buy-order endpoint is NOT in their official docs (community-known).
# Set to false to use CSFloat for listings only, not as a sell venue.
CSFLOAT_BUY_ORDERS_ENABLED=true

# --- DMarket (buy-side listings + buy-order "targets" sell venue) ---
# Both keys required for DMarket. Generate them in DMarket account > Trading API.
# Leave blank to skip DMarket entirely.
DMARKET_PUBLIC_KEY=
DMARKET_SECRET_KEY=

# --- Discord ---
# Optional. Server Settings > Integrations > Webhooks > New Webhook.
# Leave blank to just print results to the console.
DISCORD_WEBHOOK_URL=

# --- Thresholds ---
# Minimum net spread (%) after fees to report. 15 is a sensible floor.
MIN_SPREAD_PCT=15
# Ignore items cheaper than this (USD).
MIN_ITEM_PRICE_USD=5

# --- Trade-lock / buy-order safety ---
# Only flag cross-platform opps where the bought item is tradable NOW (so you can
# transfer it to fill the buy order before the order vanishes). Keep this on.
REQUIRE_TRADABLE_NOW=true
# When a feed doesn't report lock status (e.g. Skinport's items feed), keep the
# opp (flagged "unknown") instead of dropping it. Off by default = safer.
TREAT_UNKNOWN_TRADABLE_AS_OK=false
# Optional: require at least this many bids behind the top buy order (0 = off).
MIN_BUY_ORDER_DEPTH=0

# Selling-into-a-buy-order fees (%). Confirm against your account tier.
CSFLOAT_BUY_ORDER_FEE_PCT=2
DMARKET_BUY_ORDER_FEE_PCT=5
